# Production example for flow-finance.xyz after the K9 Dice Solana program is deployed.
# Do not commit real secrets in .env.production.

NEXT_PUBLIC_AGENT_K9_MINT_ADDRESS=6NHjTmLAGcN41EDzx1kofRtgLCieF233yKidydTzpump
AGENT_K9_MINT_ADDRESS=6NHjTmLAGcN41EDzx1kofRtgLCieF233yKidydTzpump

# Free/public RPC default. Replace only if you intentionally choose another free endpoint.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Set this only after an approved mainnet deployment succeeds.
NEXT_PUBLIC_AGENT_K9_DICE_PROGRAM_ID=<deployed_program_id>

# Public agent wallet for community-backed Agent K9 development.
NEXT_PUBLIC_AGENT_K9_DEVELOPMENT_WALLET=Cdij4T6EXdz1MFGChuqBNo7kZ8E5unTSLyeP8SGvazZ4

# Generate a strong production value in Vercel; do not commit it.
SESSION_SECRET=<set-in-hosting-secret-manager>
MOCK_SOLANA=0

# Agent K9 Social contest. Configure Firebase Admin only on the server.
FIREBASE_PROJECT_ID=flowfinance-social-contest
FIREBASE_CLIENT_EMAIL=<set-in-hosting-secret-manager>
FIREBASE_PRIVATE_KEY=<set-in-hosting-secret-manager-with-literal-\\n-newlines>
CONTEST_ADMIN_WALLETS=<comma-separated-admin-solana-wallets>
AGENT_K9_CONTEST_STATUS=open
AGENT_K9_CONTEST_ENDS_AT=2026-08-31T23:59:59.000Z

# Existing IOTA Crazy Dice settlement key remains separate.
SETTLEMENT_BOT_PRIVATE_KEY=<set-in-hosting-secret-manager-if-needed>

# Optional public Matrix proxy. Vercel cannot reach a local 127.0.0.1 service.
IO_BOT_API_BASE_URL=https://<reachable-io-bot-host>
