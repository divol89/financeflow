# Production example for flow-finance.xyz after the LEVI Dice Solana program is deployed.
# Do not commit real secrets in .env.production.

NEXT_PUBLIC_LEVI_MINT_ADDRESS=6baGyq4HLbUn93MQUGFqBktpXP8BRjpoxSsAap4ppump
LEVI_MINT_ADDRESS=6baGyq4HLbUn93MQUGFqBktpXP8BRjpoxSsAap4ppump

# Free/public RPC default. Replace only if you intentionally choose another free endpoint.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Set this only after approved mainnet deploy succeeds.
NEXT_PUBLIC_LEVI_DICE_PROGRAM_ID=<deployed_program_id>

# Public agent wallet for community-backed LEVI development.
NEXT_PUBLIC_LEVI_DEVELOPMENT_WALLET=Cdij4T6EXdz1MFGChuqBNo7kZ8E5unTSLyeP8SGvazZ4

# Generate a strong production value in Vercel/dashboard; do not commit it.
SESSION_SECRET=<set-in-hosting-secret-manager>
MOCK_SOLANA=0

# Existing IOTA Crazy Dice settlement key remains separate; do not commit real value.
SETTLEMENT_BOT_PRIVATE_KEY=<set-in-hosting-secret-manager-if-needed>
